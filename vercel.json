{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/supplier/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/supplier/import/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/supplier/test-apify/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/wb/search/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/wb/product/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/wb/analytics/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/check/wb-search/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/check/analyze/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/tracking/keywords/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/tracking/snapshot/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/tracking/seed/route.ts": {
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/tracking/keywords",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/tracking/snapshot",
      "schedule": "30 3 * * *"
    }
  ]
}
